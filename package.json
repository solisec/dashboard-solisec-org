{
  "name": "dashboard-solisec-org",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "gen": "wrangler types",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "better-auth": "~1.4.22",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "svelte": "^5.55.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.14",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.14",
    "wrangler": "^4.77.0"
  },
  "packageManager": "pnpm@10.33.0",
  "blockExoticSubdeps": true,
  "minimumReleaseAge": 10080,
  "trustPolicy": "no-downgrade"
}
